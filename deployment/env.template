# ==============================================================================
# InsightAI Environment Variables Configuration Template
# Copy this file to '.env' inside the root backend folder and fill in values.
# ==============================================================================

# 1. MongoDB Atlas Configuration
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/?retryWrites=true&w=majority
DATABASE_NAME=insightai

# 2. Security & JWT
JWT_SECRET=supersecretsecuritysignaturekeyinsightai2026!!!
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 3. Redis & Celery Background Processing
REDIS_URL=redis://localhost:6379/0
CELERY_ENABLED=true

# 4. MLOps Experiment Tracking
MLFLOW_TRACKING_URI=sqlite:///mlflow.db

# 5. Gemini AI Engine Configuration
GEMINI_API_KEY=AIzaSyYourGoogleGeminiApiKeyGoesHere
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=2048

# 6. File Upload Settings
UPLOAD_DIR=backend/app/uploads
